<Window x:Class="SteamGameAdder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam Game Adder" Height="700" Width="1000"
        Background="#1E1E1E" Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <DockPanel>
            <!-- Top Header -->
            <StackPanel DockPanel.Dock="Top" Background="#252525" Padding="20" Margin="0,0,0,10">
                <TextBlock Text="🎮 Steam Game Adder" FontSize="32" FontWeight="Bold" Foreground="#00D4FF"/>
                <TextBlock Text="Steam kütüphanesine herhangi bir oyunu direkt ekleyin" FontSize="12" Foreground="#808080" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Main Content -->
            <StackPanel DockPanel.Dock="Top" Margin="20" Spacing="15">
                <!-- Input Panel -->
                <GroupBox Header="Oyun Bilgileri" Foreground="#00D4FF" BorderBrush="#404040" Padding="15">
                    <Grid RowSpacing="10" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Oyun Adı -->
                        <TextBlock Text="Oyun Adı:" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        <TextBox x:Name="GameNameInput" Grid.Column="1" Padding="10" Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#404040" Height="35"/>

                        <!-- Klasör Seçimi -->
                        <TextBlock Text="Oyun Klasörü:" Grid.Row="1" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        <Grid Grid.Row="1" Grid.Column="1" ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="GamePathInput" Padding="10" Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#404040" Height="35" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="📁 Seç" Click="BrowseFolder_Click" Padding="15,0" Background="#0066FF" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </Grid>

                        <!-- App ID -->
                        <TextBlock Text="Steam App ID:" Grid.Row="2" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        <TextBox x:Name="AppIdInput" Grid.Row="2" Grid.Column="1" Padding="10" Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#404040" Height="35"/>

                        <!-- Executable -->
                        <TextBlock Text="Executable:" Grid.Row="3" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        <TextBox x:Name="ExecutableInput" Grid.Row="3" Grid.Column="1" Padding="10" Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#404040" Height="35" Text="game.exe"/>

                        <!-- Icon Seçimi -->
                        <TextBlock Text="Icon (Opsiyonel):" Grid.Row="4" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                        <Grid Grid.Row="4" Grid.Column="1" ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="IconPathInput" Padding="10" Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#404040" Height="35" IsReadOnly="True"/>
                            <Button Grid.Column="1" Content="🖼️ Seç" Click="BrowseIcon_Click" Padding="15,0" Background="#4A4A4A" Foreground="White" FontSize="12" FontWeight="Bold"/>
                        </Grid>
                    </Grid>
                </GroupBox>

                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="AddBtn" Content="➕ STEAM'E EKLE" Click="AddGame_Click" Padding="20,12" Background="#00AA00" Foreground="White" FontSize="14" FontWeight="Bold" Width="200" Cursor="Hand"/>
                    <Button x:Name="ClearBtn" Content="🗑️ Temizle" Click="Clear_Click" Padding="20,12" Background="#FF4444" Foreground="White" FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                    <Button x:Name="SettingsBtn" Content="⚙️ Ayarlar" Click="Settings_Click" Padding="20,12" Background="#4A4A4A" Foreground="White" FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>

            <!-- Game List -->
            <StackPanel DockPanel.Dock="Top" Margin="20,0,20,20" Spacing="10">
                <TextBlock Text="📋 Eklenen Oyunlar" FontSize="16" FontWeight="Bold" Foreground="#00D4FF"/>
                <DataGrid x:Name="GamesList" Height="250" Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#404040" RowBackground="#2D2D2D" AlternatingRowBackground="#252525" AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Oyun Adı" Binding="{Binding Name}" Width="300"/>
                        <DataGridTextColumn Header="App ID" Binding="{Binding AppId}" Width="100"/>
                        <DataGridTextColumn Header="Klasör" Binding="{Binding InstallPath}" Width="400"/>
                        <DataGridTextColumn Header="Eklenme Tarihi" Binding="{Binding AddedDate}" Width="150"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- List Actions -->
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Button x:Name="RemoveBtn" Content="❌ Sil" Click="RemoveGame_Click" Padding="15,8" Background="#FF6666" Foreground="White" FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                    <Button x:Name="RefreshBtn" Content="🔄 Yenile" Click="Refresh_Click" Padding="15,8" Background="#0066FF" Foreground="White" FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>

            <!-- Status Bar -->
            <TextBlock DockPanel.Dock="Bottom" x:Name="StatusText" Text="Hazır" Foreground="#808080" Padding="20" Background="#252525" BorderThickness="0,1,0,0" BorderBrush="#404040"/>
        </DockPanel>
    </Grid>
</Window>
